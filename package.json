{
  "name": "stackwerkhaus-2026",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:content": "node --test scripts/content.test.mjs",
    "test:baustellencheck": "node --test tests/baustellencheck.test.mjs",
    "test:drupal-richtext": "node --test scripts/drupal-rich-text.test.mjs",
    "test:mobile": "pnpm test:drupal-richtext && pnpm test:baustellencheck && node scripts/mobile-smoke.mjs",
    "test:smoke": "pnpm test:drupal-richtext && pnpm test:baustellencheck && node scripts/smoke.mjs",
    "start:local-prod": "next start --hostname 127.0.0.1 --port 3000",
    "lighthouse": "node scripts/lighthouse.mjs all",
    "lighthouse:home": "node scripts/lighthouse.mjs home",
    "lighthouse:blog": "node scripts/lighthouse.mjs blog",
    "lighthouse:project": "node scripts/lighthouse.mjs project",
    "remotion:studio": "remotion studio remotion/index.ts",
    "remotion:compositions": "remotion compositions remotion/index.ts",
    "remotion:still": "remotion still remotion/index.ts AnimatedBarChart output/animated-bar-chart-frame60.png --frame=60 --scale=0.35",
    "remotion:render": "remotion render remotion/index.ts AnimatedBarChart output/animated-bar-chart.mp4",
    "remotion:tiktok:still": "remotion still remotion/index.ts AnimatedBarChartTikTok output/animated-bar-chart-tiktok-frame60.png --frame=60 --scale=0.35",
    "remotion:tiktok:render": "remotion render remotion/index.ts AnimatedBarChartTikTok output/animated-bar-chart-tiktok.mp4"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "gray-matter": "^4.0.3",
    "gsap": "^3.15.0",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "next": "16.2.6",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rehype-parse": "^9.0.1",
    "rehype-sanitize": "^6.0.0",
    "resend": "^6.11.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@remotion/cli": "^4.0.469",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^10",
    "eslint-config-next": "16.2.6",
    "lighthouse": "13.3.0",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "remotion": "^4.0.469",
    "tailwindcss": "^4",
    "typescript": "^6"
  },
  "pnpm": {
    "overrides": {
      "basic-ftp": "5.3.1",
      "brace-expansion@5.0.5": "5.0.6",
      "ip-address": "10.1.1",
      "postcss": "8.5.14",
      "ws@8.17.1": "8.20.1",
      "ws@8.20.0": "8.20.1"
    }
  }
}
